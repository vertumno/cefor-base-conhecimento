# Sistema operacional
.DS_Store
Thumbs.db
desktop.ini
__MACOSX/

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Arquivos temporários
*.tmp
*.bak
*.log

# Python
__pycache__/
*.pyc

# Dumps de banco (transitórios, específicos da máquina local)
*.sql

# Arquivos grandes / binários (preferir Git LFS ou armazenamento externo)
*.zip
*.rar
*.7z
*.tar.gz

# Arquivos sensíveis
.env
.env.local
*.key
*.pem
credentials.json

# Saídas locais não versionadas
node_modules/
dist/
build/

# Exceções (arquivos pequenos que queremos manter mesmo se baterem nos padrões acima)
!.gitkeep
